<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Class Timetable"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1E3A8A"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Monday\n8:00 - 10:00 Mobile Programming\n10:00 - 12:00 Database Systems"
            android:textSize="18sp"
            android:padding="15dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tuesday\n8:00 - 10:00 Networking\n10:00 - 12:00 Software Engineering"
            android:textSize="18sp"
            android:padding="15dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Wednesday\n8:00 - 10:00 AI\n10:00 - 12:00 Research Methods"
            android:textSize="18sp"
            android:padding="15dp"
            android:background="#FFFFFF"/>
    </LinearLayout>

</ScrollView>