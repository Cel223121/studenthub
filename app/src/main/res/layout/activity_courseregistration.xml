<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Course Registration"
            android:textStyle="bold"
            android:textSize="28sp"
            android:textColor="#1E3A8A"
            android:layout_marginBottom="20dp"/>

        <CheckBox
            android:id="@+id/unit1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BIT4101 - Mobile Programming"/>

        <CheckBox
            android:id="@+id/unit2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BIT4102 - Database Systems"/>

        <CheckBox
            android:id="@+id/unit3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BIT4103 - Networking"/>

        <CheckBox
            android:id="@+id/unit4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BIT4104 - Software Engineering"/>

        <CheckBox
            android:id="@+id/unit5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BIT4105 - Artificial Intelligence"/>

        <Button
            android:id="@+id/btnRegisterUnits"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="REGISTER COURSES"
            android:layout_marginTop="25dp"
            android:backgroundTint="@color/btnPrimaryColor"/>
    </LinearLayout>

</ScrollView>